# OpenAI
OPENAI_API_KEY=sk-...
# Modelo usado para extrair os clientes do relatório (opcional)
OPENAI_MODEL=gpt-4o

# Trello — gere em https://trello.com/app-key
TRELLO_API_KEY=sua_api_key_do_trello
TRELLO_TOKEN=seu_token_do_trello
# Área de trabalho onde o quadro será criado (deixe vazio para quadros pessoais)
TRELLO_WORKSPACE=THE SMART - 2026

# Porta da interface web (opcional, padrão 3000)
PORT=3000
